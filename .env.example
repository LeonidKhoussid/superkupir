# Скопируйте в `.env` и подставьте значения.

# Обязательно для POST /v1/quiz/route (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Опционально: Bearer для POST /v1/quiz/route (если пусто — без проверки)
QUIZ_ROUTE_API_TOKEN=

# Целевой p95 времени ответа квиза (секунды), по умолчанию 10
# QUIZ_ROUTE_P95_TARGET_SEC=10

# Колбэк после пайплайна рекомендаций (см. CallbackConfig в app/config.py)
# AVALIN_CALLBACK_URL=
# AVALIN_CALLBACK_TIMEOUT=30
# AVALIN_CALLBACK_AUTH_HEADER=
# AVALIN_CALLBACK_AUTH_TOKEN=
