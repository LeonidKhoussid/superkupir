{
  "name": "superkiper-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "db:init:auth": "tsx src/scripts/run-auth-sql.ts",
    "db:init:place-interactions": "tsx src/scripts/run-auth-sql.ts sql/create_place_interactions_tables.sql",
    "db:init:wineries": "tsx src/scripts/run-auth-sql.ts sql/create_wineries_table.sql",
    "db:import:wineries": "tsx src/scripts/import-wineries.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.2",
    "@types/pg": "^8.15.6",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
